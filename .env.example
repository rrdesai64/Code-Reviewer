# Cloud LLM via OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# Local LLM via Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=codellama

# OpenAI-compatible local/cloud endpoint
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=local-model


# Production auth enforcement
AUTH_REQUIRED=false
AUTH_MODE=disabled
AUTH_SESSION_SECRET=change-me-in-production
PUBLIC_BASE_URL=http://127.0.0.1:8002
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_DEFAULT_ROLES=developer
AUTH_ADMIN_EMAILS=
AUTH_GROUP_ROLE_MAP=

# OIDC
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=
OIDC_SCOPE=openid profile email

# SAML
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_SLO_URL=
SAML_IDP_X509_CERT=
SAML_SP_ENTITY_ID=
SAML_SP_X509_CERT=
SAML_SP_PRIVATE_KEY=
SAML_WANT_ASSERTIONS_SIGNED=true
SAML_AUTHN_REQUESTS_SIGNED=false


# Phase A scanner depth: CodeQL
CODEQL_ENABLED=auto
CODEQL_EXE=
CODEQL_QUERY_SUITE=codeql-suites/code-scanning.qls
CODEQL_TIMEOUT_SECONDS=900

# Phase A scanner depth: SonarQube / SonarCloud
SONAR_ENABLED=auto
SONAR_SCANNER_EXE=
SONAR_HOST_URL=
SONAR_TOKEN=
SONAR_PROJECT_KEY=
SONAR_TIMEOUT_SECONDS=600
