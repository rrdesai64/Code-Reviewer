# Cloud LLM via OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# Local LLM via Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=codellama

# OpenAI-compatible local/cloud endpoint
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=local-model


# Production auth enforcement
AUTH_REQUIRED=false
AUTH_MODE=disabled
AUTH_SESSION_SECRET=change-me-in-production
PUBLIC_BASE_URL=http://127.0.0.1:8002
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_DEFAULT_ROLES=developer
AUTH_ADMIN_EMAILS=
AUTH_GROUP_ROLE_MAP=

# Runtime/generated output root. Use a spacious drive for bulk cloning/scanning.
SECURE_REVIEW_OUTPUT_ROOT=E:\secure-review
SECURE_REVIEW_DATA_DIR=E:\secure-review\data
REPORT_BUNDLE_DIR=E:\secure-review\reports

# OIDC
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=
OIDC_SCOPE=openid profile email

# SAML
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_SLO_URL=
SAML_IDP_X509_CERT=
SAML_SP_ENTITY_ID=
SAML_SP_X509_CERT=
SAML_SP_PRIVATE_KEY=
SAML_WANT_ASSERTIONS_SIGNED=true
SAML_AUTHN_REQUESTS_SIGNED=false


# Phase A scanner depth: Semgrep
SEMGREP_EXE=
SEMGREP_CONFIGS=
SEMGREP_TIMEOUT_SECONDS=300

# Phase A scanner depth: CodeQL
CODEQL_ENABLED=auto
CODEQL_EXE=
CODEQL_QUERY_SUITE=
CODEQL_QUERY_SUITE_PYTHON=
CODEQL_EXTRA_QUERY_SUITES=
CODEQL_THREADS=
CODEQL_RAM=
CODEQL_BUILD_MODE=
CODEQL_TIMEOUT_SECONDS=900

# Phase A scanner depth: SonarQube / SonarCloud
SONAR_ENABLED=auto
SONAR_SCANNER_EXE=
SONAR_HOST_URL=
SONAR_TOKEN=
SONAR_PROJECT_KEY=
SONAR_ORGANIZATION=
SONAR_QUALITY_GATE_ENABLED=true
SONAR_QUALITY_GATE_WAIT=false
SONAR_QUALITY_GATE_TIMEOUT=300
SONAR_ISSUE_TYPES=VULNERABILITY,SECURITY_HOTSPOT,BUG,CODE_SMELL
SONAR_SEVERITIES=
SONAR_ISSUE_PAGE_SIZE=500
SONAR_TIMEOUT_SECONDS=600

# Go dependency vulnerability scanning
GOVULNCHECK_ENABLED=auto
GOVULNCHECK_EXE=
GOVULNCHECK_TIMEOUT_SECONDS=300
GO_EXE=

# Point 1: Secret scanning and push protection
SECRET_SCAN_ENABLED=true
SECRET_SCAN_MAX_FILE_BYTES=1048576
SECRET_SCAN_EXTERNAL_ENABLED=auto
PUSH_PROTECTION_ENABLED=true
SECRET_POLICY_BLOCK_SEVERITY=HIGH
GITLEAKS_ENABLED=auto
GITLEAKS_EXE=
GITLEAKS_TIMEOUT_SECONDS=180
TRUFFLEHOG_ENABLED=auto
TRUFFLEHOG_EXE=
TRUFFLEHOG_TIMEOUT_SECONDS=180

# Point 2: GitHub PR-native review
GITHUB_API_URL=https://api.github.com
GITHUB_API_VERSION=2026-03-10
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_PR_NUMBER=
GITHUB_DRY_RUN=true
GITHUB_FETCH_PR_DIFF=false
GITHUB_REVIEW_EVENT=COMMENT
GITHUB_MAX_INLINE_COMMENTS=25
GITHUB_MIN_INLINE_RISK=40
GITHUB_INLINE_CONTEXT_LINES=false
GITHUB_PUBLISH_STATUS=false
GITHUB_STATUS_CONTEXT=Secure Code Review
GITHUB_STATUS_TARGET_URL=
GITHUB_WARN_AS_FAILURE=false
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_ALLOW_UNSIGNED=false
# Point 9: Issue planning with Jira/Linear
# Defaults are dry-run. Real issue creation requires request publish=true and provider dry-run=false.
JIRA_ENABLED=auto
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task
JIRA_LABELS=secure-review,security
JIRA_COMPONENTS=
JIRA_DRY_RUN=true
JIRA_PRIORITY_P0=Highest
JIRA_PRIORITY_P1=High
JIRA_PRIORITY_P2=Medium
JIRA_PRIORITY_P3=Low
JIRA_PRIORITY_P4=Lowest

LINEAR_ENABLED=auto
LINEAR_API_URL=https://api.linear.app/graphql
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_LABEL_IDS=
LINEAR_PROJECT_ID=
LINEAR_DRY_RUN=true
LINEAR_PRIORITY_P0=1
LINEAR_PRIORITY_P1=2
LINEAR_PRIORITY_P2=3
LINEAR_PRIORITY_P3=4
LINEAR_PRIORITY_P4=0
# Point 10: Slack/Teams agent
# Defaults are dry-run. Real chat publishing requires request publish=true and provider dry-run=false.
CHAT_PUBLIC_BASE_URL=
CHAT_MAX_FINDINGS=10

SLACK_ENABLED=auto
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=
SLACK_ALLOW_UNSIGNED=false
SLACK_DRY_RUN=true
SLACK_CHANNEL=
SLACK_USERNAME=Secure Review
SLACK_ICON_EMOJI=:shield:

TEAMS_ENABLED=auto
TEAMS_WEBHOOK_URL=
TEAMS_COMMAND_SECRET=
TEAMS_ALLOW_UNSIGNED=false
TEAMS_DRY_RUN=true
# Point 11: GitLab, Azure DevOps, and Bitbucket
# Defaults are dry-run. Real review publishing requires request publish=true and provider dry-run=false.
CODE_HOST_PUBLIC_BASE_URL=

GITLAB_ENABLED=auto
GITLAB_API_URL=https://gitlab.com/api/v4
GITLAB_TOKEN=
GITLAB_PROJECT_ID=
GITLAB_MR_IID=
GITLAB_COMMIT_SHA=
GITLAB_DRY_RUN=true
GITLAB_PUBLISH_STATUS=false
GITLAB_STATUS_CONTEXT=Secure Code Review
GITLAB_STATUS_TARGET_URL=

AZURE_DEVOPS_ENABLED=auto
AZURE_DEVOPS_API_URL=https://dev.azure.com
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_REPOSITORY_ID=
AZURE_DEVOPS_PR_ID=
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_API_VERSION=7.1
AZURE_DEVOPS_COMMIT_SHA=
AZURE_DEVOPS_DRY_RUN=true
AZURE_DEVOPS_PUBLISH_STATUS=false
AZURE_DEVOPS_STATUS_CONTEXT=Secure Code Review
AZURE_DEVOPS_STATUS_TARGET_URL=

BITBUCKET_ENABLED=auto
BITBUCKET_DEPLOYMENT=cloud
BITBUCKET_API_URL=https://api.bitbucket.org/2.0
BITBUCKET_TOKEN=
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_WORKSPACE=
BITBUCKET_PROJECT_KEY=
BITBUCKET_REPO_SLUG=
BITBUCKET_PR_ID=
BITBUCKET_COMMIT_SHA=
BITBUCKET_DRY_RUN=true
BITBUCKET_PUBLISH_STATUS=false
BITBUCKET_STATUS_KEY=secure-review
BITBUCKET_STATUS_NAME=Secure Code Review
BITBUCKET_STATUS_TARGET_URL=
